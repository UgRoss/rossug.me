---
import '@/styles/global.css'
import BaseHead from '@/components/layout/BaseHead.astro'
import Footer from '@/components/layout/Footer.astro'
import { themeConfig } from '@/config'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { formatPageTitle } from '@/utils/seo'

interface Props {
  description?: string
  title?: string
}

const { description, title } = Astro.props
const metaTitle = formatPageTitle(title)
const metaDescription = description ?? themeConfig.site.description
---

<BaseLayout type="page">
  <BaseHead description={metaDescription} slot="head" title={metaTitle} />
  <div class="page-content">
    <main>
      <slot />
    </main>
    {
      themeConfig.general.footer && (
        <div>
          <Footer />
        </div>
      )
    }
  </div>
</BaseLayout>

<style is:global>
  .page-content {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .page-content main {
    flex: 1;
  }
</style>
