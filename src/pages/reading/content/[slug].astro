---
// ABOUTME: Lightweight content endpoint page for lazily loading book markdown into the reading dialog.
// ABOUTME: Statically renders per-book markdown body without the full standalone page layout.

import { render } from 'astro:content'

import type { BookEntry } from '@/utils/books'

import { getFilteredBooks } from '@/utils/books'

export async function getStaticPaths() {
  const books = await getFilteredBooks()
  return books.map((book) => ({
    params: { slug: book.id },
    props: { book }
  }))
}

const { book } = Astro.props as { book: BookEntry }
const { Content } = await render(book)
---

<Content />
