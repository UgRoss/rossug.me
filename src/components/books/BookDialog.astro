---
// ABOUTME: Route-driven native dialog overlay for book details on the /reading list page.
// ABOUTME: Opens over the list with pushState URL sync; falls back to /reading/[slug] without JS.

import type { BookEntry } from '@/utils/books'

import BookRating from '@/components/books/BookRating.astro'

interface Props {
  books: BookEntry[]
}

const { books } = Astro.props
---

<dialog
  class="book-dialog fixed inset-0 m-0 h-dvh max-h-none w-full max-w-none bg-transparent p-0 backdrop:bg-neutral-900/40 backdrop:backdrop-blur-sm open:flex open:items-center open:justify-center dark:backdrop:bg-white/8"
  id="book-dialog"
>
  <div
    class="book-dialog-panel relative flex max-h-[90vh] w-[95vw] max-w-5xl flex-col overflow-hidden rounded-3xl bg-white shadow-2xl ring-1 ring-black/5 dark:bg-neutral-900 dark:ring-white/10"
  >
    <header
      class="flex items-center justify-end border-b border-neutral-100 bg-white px-4 py-3 dark:border-neutral-700 dark:bg-neutral-900"
    >
      <button
        aria-label="Close"
        class="book-dialog-close rounded-full bg-white/80 p-2 shadow-sm backdrop-blur-md transition-colors hover:bg-neutral-100 dark:bg-neutral-800/80 dark:hover:bg-neutral-800"
        type="button"
      >
        <svg
          class="h-5 w-5 text-neutral-400 dark:text-neutral-300"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </header>

    <div class="book-dialog-body min-h-0 overflow-y-auto">
      {
        books.map((book) => (
          <article class="book-dialog-content hidden" data-book-id={book.id}>
            <div class="flex w-full flex-col sm:flex-row">
              <div class="flex w-full shrink-0 flex-col items-center gap-6 border-b border-neutral-100 bg-neutral-50 p-8 text-center sm:w-1/3 sm:items-start sm:border-r sm:border-b-0 sm:text-left dark:border-neutral-700 dark:bg-neutral-800">
                <div class="h-60 w-40 shrink-0 overflow-hidden rounded-xl shadow-2xl">
                  <img
                    alt={book.data.title}
                    class="h-full w-full object-cover"
                    src={book.data.cover.src}
                  />
                </div>
                <div class="w-full space-y-2">
                  <h2 class="text-xl leading-tight font-bold">{book.data.title}</h2>
                  <p class="text-neutral-500">{book.data.author}</p>
                  <BookRating
                    className="flex justify-center gap-1 pt-2 sm:justify-start"
                    iconClassName="h-3.5 w-3.5"
                    rating={book.data.rating}
                  />
                </div>
              </div>

              <div class="w-full space-y-8 p-8 sm:w-2/3 sm:p-10">
                <section class="space-y-4">
                  <h3 class="text-xs font-semibold tracking-widest text-neutral-400 uppercase">
                    Summary
                  </h3>
                  <p class="border-l-2 border-neutral-100 pl-4 leading-relaxed text-neutral-600 italic dark:border-neutral-700 dark:text-neutral-400">
                    {book.data.summary}
                  </p>
                </section>

                <section class="book-dialog-markdown prose max-w-none prose-neutral dark:prose-invert">
                  <p class="text-sm text-neutral-500 dark:text-neutral-400">Loading notes...</p>
                </section>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</dialog>

<script>
  function initBookDialog() {
    const dialogElement = document.getElementById('book-dialog')
    if (!(dialogElement instanceof HTMLDialogElement)) return

    const dialog = dialogElement
    const desktopDialogQuery = window.matchMedia('(min-width: 640px)')

    const closeBtn = dialog.querySelector('.book-dialog-close')
    const contents = dialog.querySelectorAll<HTMLElement>('.book-dialog-content')
    const contentCache = new Map<string, string>()
    const contentRequests = new Map<string, Promise<string>>()
    let activeSlug: null | string = null
    let openFrame: null | number = null

    function shouldUseDialog(): boolean {
      return desktopDialogQuery.matches
    }

    async function fetchBookContent(slug: string): Promise<string> {
      const inFlight = contentRequests.get(slug)
      if (inFlight) return inFlight

      const request = fetch(`/reading/content/${slug}/`).then(async (response) => {
        if (!response.ok) {
          throw new Error(`Failed to load content for ${slug}`)
        }

        const html = await response.text()
        contentCache.set(slug, html)
        return html
      })

      contentRequests.set(slug, request)

      try {
        return await request
      } finally {
        contentRequests.delete(slug)
      }
    }

    async function loadBookContent(slug: string) {
      const article = [...contents].find((el) => el.dataset.bookId === slug)
      if (!article) return

      const container = article.querySelector<HTMLElement>('.book-dialog-markdown')
      if (!container) return

      if (container.dataset.loaded === 'true') return

      const cached = contentCache.get(slug)
      if (cached) {
        container.innerHTML = cached
        container.dataset.loaded = 'true'
        return
      }

      try {
        const html = await fetchBookContent(slug)
        container.innerHTML = html
        container.dataset.loaded = 'true'
      } catch {
        container.innerHTML =
          '<p class="text-sm text-red-600 dark:text-red-400">Could not load notes right now.</p>'
      }
    }

    function showBook(slug: string) {
      if (!shouldUseDialog()) return

      if (openFrame !== null) {
        window.cancelAnimationFrame(openFrame)
        openFrame = null
      }

      if (dialog.open && activeSlug === slug) return

      contents.forEach((el) => {
        el.classList.toggle('hidden', el.dataset.bookId !== slug)
      })

      const visibleContent = [...contents].find((el) => el.dataset.bookId === slug)
      const title = visibleContent?.querySelector('h2')?.textContent ?? 'Book details'
      dialog.setAttribute('aria-label', title)

      activeSlug = slug
      void loadBookContent(slug)

      // Let layout settle before opening so the drawer animates from its final size.
      void dialog.offsetHeight
      openFrame = window.requestAnimationFrame(() => {
        if (dialog.open) return

        dialog.showModal()
        document.body.style.overflow = 'hidden'
        openFrame = null
      })
    }

    function closeDialog(restoreUrl = true) {
      if (openFrame !== null) {
        window.cancelAnimationFrame(openFrame)
        openFrame = null
      }

      if (!dialog.open) return
      dialog.close()
      document.body.style.overflow = ''
      if (restoreUrl && activeSlug) {
        window.history.pushState({}, '', '/reading')
      }
      activeSlug = null
    }

    // Listen for card click events
    function handleDialogOpen(e: Event) {
      const slug = (e as CustomEvent).detail?.slug
      if (slug && shouldUseDialog()) showBook(slug)
    }

    function handleViewportChange() {
      if (!shouldUseDialog() && dialog.open) {
        closeDialog(false)
      }
    }

    // Close button
    closeBtn?.addEventListener('click', () => closeDialog())

    // Backdrop click closes dialog
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) closeDialog()
    })

    // Native dialog cancel (Escape key) syncs URL
    dialog.addEventListener('cancel', (e) => {
      e.preventDefault()
      closeDialog()
    })

    // Browser back/forward
    function handlePopState() {
      const match = window.location.pathname.match(/^\/reading\/(.+)$/)
      if (match && shouldUseDialog()) {
        showBook(match[1])
      } else if (dialog.open) {
        closeDialog(false)
      }
    }

    window.addEventListener('book-dialog-open', handleDialogOpen)
    window.addEventListener('popstate', handlePopState)
    desktopDialogQuery.addEventListener('change', handleViewportChange)

    // Cleanup for Astro view transitions
    document.addEventListener(
      'astro:before-preparation',
      () => {
        window.removeEventListener('book-dialog-open', handleDialogOpen)
        window.removeEventListener('popstate', handlePopState)
        desktopDialogQuery.removeEventListener('change', handleViewportChange)
        if (openFrame !== null) {
          window.cancelAnimationFrame(openFrame)
          openFrame = null
        }
        if (dialog.open) {
          dialog.close()
          document.body.style.overflow = ''
        }
      },
      { once: true }
    )
  }

  document.addEventListener('astro:page-load', initBookDialog)
</script>

<style>
  .book-dialog::backdrop {
    animation: backdrop-fade-in 0.2s ease-out;
  }

  .book-dialog[open] .book-dialog-panel {
    animation: panel-zoom-in 0.25s ease-out;
    transform-origin: center center;
  }

  @keyframes backdrop-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes panel-zoom-in {
    from {
      transform: translateY(8px) scale(0.98);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>
