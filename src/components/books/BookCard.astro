---
// ABOUTME: Book cover card component that links to the standalone book detail page.
// ABOUTME: Displays cover image, title, and author with hover effects.

import type { BookData } from '@/utils/books'

interface Props {
  book: BookData
  grayscale?: boolean
}

const { book, grayscale = true } = Astro.props
---

<a class="group block w-full space-y-3" href={`/reading/${book.id}`}>
  <div
    class="relative aspect-2/3 w-full shrink-0 overflow-hidden rounded-lg bg-neutral-100 shadow-md transition-all duration-500 group-hover:-translate-y-1 group-hover:shadow-xl"
  >
    <img
      alt={book.title}
      class:list={[
        'h-full w-full object-cover transition-all duration-700',
        grayscale && 'grayscale group-hover:grayscale-0'
      ]}
      loading="lazy"
      src={book.coverSrc}
    />
  </div>

  <div class="space-y-1">
    <h3 class="text-sm leading-tight font-bold transition-colors group-hover:text-neutral-600">
      {book.title}
    </h3>
    <p class="text-[11px] font-medium text-neutral-400">
      {book.author}
    </p>
  </div>
</a>
