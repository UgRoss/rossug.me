---
import { themeConfig } from '@/config'

const today = new Date()

const navLinks = [
  { href: '/colophon', label: 'Colophon' },
  { href: '/rss.xml', label: 'RSS' }
]
---

<footer class="mt-8 border-t border-(--border)">
  <div
    class="flex flex-col items-start justify-between gap-4 py-4 font-medium sm:flex-row sm:items-center"
  >
    <div class="text-(length:--font-size-m) text-muted">
      &copy; {today.getFullYear()}
      {themeConfig.site.author}
    </div>

    <div class="flex items-center gap-2 text-(length:--font-size-m)">
      {
        navLinks.map((link, index) => (
          <>
            {index > 0 && (
              <span aria-hidden="true" class="text-faint">
                ·
              </span>
            )}
            <a class="text-muted transition-colors hover:text-(--text-primary)" href={link.href}>
              {link.label}
            </a>
          </>
        ))
      }
    </div>
  </div>
</footer>
