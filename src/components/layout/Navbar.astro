---
// ABOUTME: Full-width site header with avatar, primary nav links, "More" dropdown, and theme toggle.
// ABOUTME: Responsive design hides the avatar on small screens to conserve space.

import Dropdown from '@/components/ui/Dropdown.astro'
import ThemeToggle from '@/components/ui/ThemeToggle'
import { themeConfig } from '@/config'

const currentPath = Astro.url.pathname

interface NavItem {
  href: string
  label: string
}

const primaryLinks: NavItem[] = [
  { href: '/', label: 'About' },
  { href: '/blog', label: 'Blog' }
]

const moreLinks: NavItem[] = [
  { href: '/notes', label: 'Notes' },
  { href: '/reading', label: 'Reading' },
  { href: '/uses', label: 'Uses' }
]

const navLinkClass =
  'flex items-center gap-1 rounded-md px-3 py-1.5 text-[length:var(--font-size-m)] font-medium text-(--text-secondary) no-underline transition-colors duration-150 hover:bg-(--selection) hover:text-(--text-primary)'

const dropdownItemClass =
  'block rounded-md px-3 py-1.5 text-[length:var(--font-size-m)] font-medium text-(--text-secondary) no-underline transition-colors duration-150 hover:bg-(--selection) hover:text-(--text-primary)'

const isActive = (href: string): boolean => {
  if (href === '/') return currentPath === '/'
  return currentPath.startsWith(href)
}

const isMoreActive = moreLinks.some((link) => isActive(link.href))
---

<header
  class="navbar-header sticky top-0 z-50 border-b border-transparent bg-[color-mix(in_srgb,var(--bg)_80%,transparent)] py-2 backdrop-blur-md"
>
  <nav
    aria-label="Main navigation"
    class="container mx-auto flex h-12 max-w-150 items-center justify-between"
  >
    <div class="flex items-center gap-1 sm:gap-2">
      {
        primaryLinks.map((link) => (
          <a
            aria-current={isActive(link.href) ? 'page' : undefined}
            class:list={[navLinkClass, { 'is-active bg-(--selection)': isActive(link.href) }]}
            href={link.href}
          >
            {link.label}
          </a>
        ))
      }

      <Dropdown class="navbar-more-dropdown">
        <span
          aria-current={isMoreActive ? 'page' : undefined}
          class:list={[
            navLinkClass,
            'font-inherit tracking-inherit',
            { 'is-active': isMoreActive }
          ]}
          slot="trigger"
        >
          More
          <svg
            aria-hidden="true"
            class="navbar-chevron transition-transform duration-200"
            fill="none"
            height="12"
            viewBox="0 0 12 12"
            width="12"
          >
            <path
              d="M3 4.5L6 7.5L9 4.5"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"></path>
          </svg>
        </span>
        {
          moreLinks.map((link) => (
            <a
              aria-current={isActive(link.href) ? 'page' : undefined}
              class:list={[dropdownItemClass, { 'is-active': isActive(link.href) }]}
              href={link.href}
            >
              {link.label}
            </a>
          ))
        }
      </Dropdown>
    </div>

    {themeConfig.general.themeToggle && <ThemeToggle client:idle />}
  </nav>
</header>

<script is:inline>
  const NAVBAR_SCROLL_HANDLER_KEY = '__navbarScrollHandler'

  const initNavbarScroll = () => {
    const header = document.querySelector('.navbar-header')
    if (!(header instanceof HTMLElement)) return

    const previousHandler = window[NAVBAR_SCROLL_HANDLER_KEY]
    if (typeof previousHandler === 'function') {
      window.removeEventListener('scroll', previousHandler)
    }

    const updateBorder = () => {
      if (window.scrollY > 0) {
        header.classList.add('border-(--border)')
        header.classList.remove('border-transparent')
      } else {
        header.classList.remove('border-(--border)')
        header.classList.add('border-transparent')
      }
    }

    updateBorder()
    window.addEventListener('scroll', updateBorder, { passive: true })
    window[NAVBAR_SCROLL_HANDLER_KEY] = updateBorder
  }

  initNavbarScroll()
  document.addEventListener('astro:page-load', initNavbarScroll)
</script>

<style>
  .is-active {
    color: var(--text-primary);
  }

  .navbar-more-dropdown[open] .navbar-chevron {
    transform: rotate(180deg);
  }
</style>
