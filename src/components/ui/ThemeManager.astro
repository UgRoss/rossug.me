<!--
  This is a critical style block to prevent flashing on page load in dark mode.
  It is injected into the <head> of the document before the main stylesheets are loaded.
-->
<style is:inline>
  :root {
    --bg: #ffffff;
  }

  html.dark {
    --bg: #1c1c1c;
    color-scheme: dark;
  }

  html {
    background-color: var(--bg);
    color-scheme: light;
  }
</style>

<script is:inline>
  ;(function () {
    const SYSTEM_THEME_QUERY = '(prefers-color-scheme: dark)'
    const STORAGE_KEY = 'rossug-theme'

    // Apply as early as possible to avoid initial flash.
    let storedTheme = null
    try {
      storedTheme = localStorage.getItem(STORAGE_KEY)
    } catch {
      storedTheme = null
    }

    const appliedTheme =
      storedTheme === 'light' || storedTheme === 'dark'
        ? storedTheme
        : window.matchMedia(SYSTEM_THEME_QUERY).matches
          ? 'dark'
          : 'light'

    document.documentElement.classList.toggle('dark', appliedTheme === 'dark')
    document.documentElement.classList.toggle('light', appliedTheme === 'light')
  })()
</script>

<script>
  import { getMode, syncTheme } from '@/utils/theme-controller'

  const themeWindow = window as Window & { __themeManagerListenersBound?: boolean }

  syncTheme()

  if (!themeWindow.__themeManagerListenersBound) {
    const media = window.matchMedia('(prefers-color-scheme: dark)')

    media.addEventListener('change', () => {
      if (getMode() === 'system') {
        syncTheme()
      }
    })

    document.addEventListener('astro:after-swap', () => {
      syncTheme()
    })

    themeWindow.__themeManagerListenersBound = true
  }
</script>
