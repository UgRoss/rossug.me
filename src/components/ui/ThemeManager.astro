<!--
  This is a critical style block to prevent flashing on page load in dark mode.
  It is injected into the <head> of the document before the main stylesheets are loaded.
-->
<style is:inline>
  :root {
    --bg: #ffffff;
  }

  html.dark {
    --bg: #1c1c1c;
  }

  html {
    background-color: var(--bg);
    color-scheme: light;
  }

  html.dark {
    color-scheme: dark;
  }
</style>

<script is:inline>
  // Global Theme Manager
  ;(function () {
    const SYSTEM_THEME_QUERY = '(prefers-color-scheme: dark)'

    // Prevent duplicate initialization
    if (window.ThemeManager && window.ThemeManager.initialized) {
      return
    }

    window.ThemeManager = {
      applyTheme(theme) {
        document.documentElement.classList.remove('light', 'dark')
        document.documentElement.classList.add(theme)

        // Dispatch event for other components
        document.dispatchEvent(
          new CustomEvent('themechange', {
            detail: {
              isSystemTheme: this.isUsingSystemTheme(),
              isUserChoice: !this.isUsingSystemTheme(),
              theme
            }
          })
        )
      },
      getEffectiveTheme() {
        return this.getStoredTheme() || this.getSystemTheme()
      },

      getStoredTheme() {
        try {
          const storedTheme = localStorage.getItem(this.STORAGE_KEY)
          return storedTheme === 'light' || storedTheme === 'dark' ? storedTheme : null
        } catch {
          return null
        }
      },

      getSystemTheme() {
        return window.matchMedia(SYSTEM_THEME_QUERY).matches ? 'dark' : 'light'
      },

      init() {
        if (this.initialized) return

        const systemThemeMedia = window.matchMedia(SYSTEM_THEME_QUERY)

        // Set initial theme.
        this.applyTheme(this.getEffectiveTheme())

        // Follow OS preference changes only while in system mode.
        systemThemeMedia.addEventListener('change', () => {
          if (this.isUsingSystemTheme()) {
            this.applyTheme(this.getSystemTheme())
          }
        })

        const syncThemeAfterNavigation = () => {
          const effectiveTheme = this.getEffectiveTheme()
          const appliedTheme = document.documentElement.classList.contains('dark')
            ? 'dark'
            : 'light'

          if (effectiveTheme !== appliedTheme) {
            requestAnimationFrame(() => {
              this.applyTheme(effectiveTheme)
            })
          }
        }

        document.addEventListener('astro:before-preparation', syncThemeAfterNavigation)
        document.addEventListener('astro:after-swap', syncThemeAfterNavigation)

        this.initialized = true
      },

      initialized: false,

      isUsingSystemTheme() {
        return this.getStoredTheme() === null
      },

      setStoredTheme(theme) {
        try {
          if (theme === 'system') {
            localStorage.removeItem(this.STORAGE_KEY)
            return
          }

          localStorage.setItem(this.STORAGE_KEY, theme)
        } catch (e) {
          console.warn('Failed to store theme preference:', e)
        }
      },

      setTheme(theme) {
        this.setStoredTheme(theme)

        const effectiveTheme = theme === 'system' ? this.getSystemTheme() : theme
        this.applyTheme(effectiveTheme)
      },

      STORAGE_KEY: 'chiri-theme',

      toggle() {
        const currentTheme = this.getEffectiveTheme()
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark'
        this.setTheme(newTheme)
      }
    }

    // Initialize theme manager
    window.ThemeManager.init()
  })()
</script>
