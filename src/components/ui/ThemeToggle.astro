---
// ABOUTME: Theme selector dropdown with Automatic, Light, and Dark options.
// ABOUTME: Shows sun/moon icon based on current theme, with a check mark on the active option.

import { themeConfig } from '@/config'

import checkIcon from '@/assets/icons/check.svg?raw'
import moonIcon from '@/assets/icons/moon.svg?raw'
import sunIcon from '@/assets/icons/sun.svg?raw'

import Dropdown from '@/components/ui/Dropdown.astro'

const themeOptions = [
  { label: 'Automatic', value: 'system' },
  { label: 'Light', value: 'light' },
  { label: 'Dark', value: 'dark' }
] as const
---

{
  themeConfig.general.themeToggle && (
    <Dropdown align="right" id="theme-selector" triggerAriaLabel="Theme settings">
      <span
        slot="trigger"
        class="flex size-8 cursor-pointer items-center justify-center rounded-md text-(--text-secondary) transition-colors duration-150 hover:bg-(--selection) hover:text-(--text-primary)"
      >
        <span
          class="theme-icon-sun leading-none [&>svg]:size-[1.125rem]"
          aria-hidden="true"
          set:html={sunIcon}
        />
        <span
          class="theme-icon-moon hidden leading-none [&>svg]:size-[1.125rem]"
          aria-hidden="true"
          set:html={moonIcon}
        />
      </span>
      {themeOptions.map(({ label, value }) => (
        <button
          class="theme-option font-inherit tracking-inherit flex w-full cursor-pointer items-center gap-2 rounded-md border-none bg-transparent px-3 py-1.5 text-left text-[length:var(--font-size-m)] font-medium text-(--text-secondary) transition-colors duration-150 hover:bg-(--selection) hover:text-(--text-primary)"
          data-theme={value}
          type="button"
        >
          <span
            class="theme-check shrink-0 leading-none opacity-0 [&>svg]:size-3.5"
            aria-hidden="true"
            set:html={checkIcon}
          />
          {label}
        </button>
      ))}
    </Dropdown>
  )
}

<script is:inline>
  const THEME_SELECTOR_ID = 'theme-selector'
  const THEME_SELECTOR_BOUND = 'data-theme-selector-bound'
  const THEME_CHANGE_HANDLER_BOUND_KEY = '__themeSelectorThemeChangeHandlerBound'
  const THEME_OPTION_SELECTOR = '.theme-option'
  const THEME_ICON_SUN_SELECTOR = '.theme-icon-sun'
  const THEME_ICON_MOON_SELECTOR = '.theme-icon-moon'

  const getThemeSelector = () => document.getElementById(THEME_SELECTOR_ID)

  const initThemeSelector = () => {
    const selector = getThemeSelector()
    if (!selector || !window.ThemeManager) return

    if (selector.getAttribute(THEME_SELECTOR_BOUND) === 'true') {
      syncThemeSelectorUI(selector)
      return
    }

    selector.setAttribute(THEME_SELECTOR_BOUND, 'true')

    selector.addEventListener('click', (event) => {
      const target = event.target
      if (!(target instanceof Element)) return

      const option = target.closest(THEME_OPTION_SELECTOR)
      if (!(option instanceof HTMLElement)) return

      const theme = option.getAttribute('data-theme')
      if (!theme) return

      window.ThemeManager.setTheme(theme)
      selector.removeAttribute('open')
      syncThemeSelectorUI(selector)
    })

    if (!window[THEME_CHANGE_HANDLER_BOUND_KEY]) {
      document.addEventListener('themechange', () => {
        const currentSelector = getThemeSelector()
        if (!currentSelector) return
        syncThemeSelectorUI(currentSelector)
      })

      window[THEME_CHANGE_HANDLER_BOUND_KEY] = true
    }

    syncThemeSelectorUI(selector)
  }

  const getThemeMode = () => {
    if (!window.ThemeManager) return 'system'
    if (window.ThemeManager.isUsingSystemTheme()) return 'system'
    return window.ThemeManager.getStoredTheme() || 'system'
  }

  const syncThemeSelectorUI = (selector) => {
    const isDark = document.documentElement.classList.contains('dark')
    const sunEl = selector.querySelector(THEME_ICON_SUN_SELECTOR)
    const moonEl = selector.querySelector(THEME_ICON_MOON_SELECTOR)
    if (sunEl) sunEl.style.display = isDark ? 'none' : 'block'
    if (moonEl) moonEl.style.display = isDark ? 'block' : 'none'

    const mode = getThemeMode()
    const options = selector.querySelectorAll(THEME_OPTION_SELECTOR)
    for (const option of options) {
      const isSelected = option.getAttribute('data-theme') === mode
      option.setAttribute('aria-pressed', String(isSelected))
      option.classList.toggle('selected', isSelected)
    }
  }

  initThemeSelector()
  document.addEventListener('astro:page-load', initThemeSelector)
</script>

<style>
  .theme-option.selected {
    color: var(--text-primary);
  }

  .theme-option.selected .theme-check {
    opacity: 1;
  }
</style>
