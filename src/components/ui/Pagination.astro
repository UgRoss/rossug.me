---
interface Props {
  currentPage: number
  lastPage: number
  nextUrl?: string
  prevUrl?: string
}

const { currentPage, lastPage, nextUrl, prevUrl } = Astro.props

const linkClass = 'text-secondary transition-colors hover:text-(--text-primary)'
const disabledClass = 'text-tertiary'
---

{
  lastPage > 1 && (
    <nav aria-label="Pagination" class="mt-12 flex items-center justify-between pt-8 text-sm">
      {prevUrl ? (
        <a aria-label="Go to previous page" class={linkClass} href={prevUrl}>
          &larr; Prev
        </a>
      ) : (
        <span class={disabledClass}>&larr; Prev</span>
      )}

      <span class="text-tertiary">
        {currentPage} / {lastPage}
      </span>

      {nextUrl ? (
        <a aria-label="Go to next page" class={linkClass} href={nextUrl}>
          Next &rarr;
        </a>
      ) : (
        <span class={disabledClass}>Next &rarr;</span>
      )}
    </nav>
  )
}
