---
import type { CollectionEntry } from 'astro:content'

import { Image } from 'astro:assets'

import FormattedDate from '@/components/ui/FormattedDate.astro'
import { createExcerpt, truncateAtWord } from '@/utils/excerpt'
import { blogPath } from '@/utils/paths'

interface Props {
  posts: CollectionEntry<'posts'>[]
}

const { posts } = Astro.props

const EXCERPT_LENGTH = 120

const getPostExcerpt = (post: Props['posts'][number]): string =>
  truncateAtWord(post.data.excerpt ?? createExcerpt(post.body ?? ''), EXCERPT_LENGTH)
---

<ul class="mt-8 space-y-8">
  {
    posts.map((post) => (
      <li class="list-none">
        <article>
          <a
            class="group -mx-4 block rounded-xl px-4 py-4 no-underline transition-colors hover:bg-(--selection) focus-visible:bg-(--selection)"
            href={blogPath(post.id)}
          >
            {post.data.image && (
              <div class="mb-5 overflow-hidden rounded-2xl bg-(--code-bg)">
                <Image
                  alt={post.data.title}
                  class="h-auto w-full object-cover transition-transform duration-300 group-hover:scale-[1.01]"
                  loading="lazy"
                  sizes="(max-width: 672px) 100vw, 672px"
                  src={post.data.image}
                  widths={[672, 1344]}
                />
              </div>
            )}

            <div class="flex items-start justify-between gap-4">
              <h2 class="inline-block pb-0.5 text-lg leading-tight text-(--text-primary)">
                {post.data.title}
              </h2>

              <p class="shrink-0 pt-1 text-sm text-tertiary">
                <FormattedDate date={post.data.pubDate} />
              </p>
            </div>

            <p class="mt-2 max-w-3xl text-secondary">{getPostExcerpt(post)}</p>
          </a>
        </article>
      </li>
    ))
  }
</ul>
