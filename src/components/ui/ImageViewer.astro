<div class="image-viewer" id="image-viewer">
  <img alt="" id="image-viewer-img" src="" />
</div>

<script>
  function initImageViewer() {
    const viewer = document.getElementById('image-viewer')
    const viewerImg = document.getElementById('image-viewer-img') as HTMLImageElement

    if (!viewer) {
      return
    }

    // Display image in fullscreen viewer overlay
    function showImage(src: string, alt?: string) {
      if (!viewer) {
        return
      }

      if (viewerImg && src) {
        viewerImg.src = src
        viewerImg.alt = alt || ''
      }
      // Show visibility first
      viewer.style.visibility = 'visible'
      void viewer.offsetWidth
      viewer.classList.add('active')
      document.body.classList.add('image-viewer-open')
      document.body.style.overflow = 'hidden'
      document.body.dataset.scrollY = window.scrollY.toString()
      viewer.style.cursor = 'auto'
      setTimeout(() => {
        viewer.style.cursor = ''
      }, 10)
    }

    // Hide the image viewer and restore page scroll
    function hideImage() {
      if (!viewer) {
        return
      }

      viewer.classList.remove('active')
      document.body.classList.remove('image-viewer-open')
      document.body.style.overflow = ''
    }

    // Bind click events to images with data-preview="true" attribute
    function bindImageClickEvents() {
      const previewImages = document.querySelectorAll('img[data-preview="true"]')
      previewImages.forEach((img) => {
        const imgElement = img as HTMLImageElement
        if (imgElement.dataset.viewerBound) return
        imgElement.dataset.viewerBound = 'true'
        imgElement.style.cursor = 'zoom-in'
        imgElement.addEventListener('click', (e) => {
          e.preventDefault()
          const target = e.target as HTMLImageElement
          showImage(target.src, target.alt || '')
        })
      })
    }

    // Viewer-level listeners bind once per element: init runs for both
    // DOMContentLoaded and astro:page-load on the initial page view.
    if (!viewer.dataset.bound) {
      viewer.dataset.bound = 'true'

      // Hide and clear image after transition ends
      viewer.addEventListener('transitionend', (e) => {
        if (e.propertyName === 'opacity' && !viewer.classList.contains('active')) {
          viewer.style.visibility = 'hidden'
          if (viewerImg) {
            viewerImg.src = ''
            viewerImg.alt = ''
          }
          viewer.style.cursor = 'auto'
          setTimeout(() => {
            viewer.style.cursor = ''
          }, 10)
        }
      })

      viewer.addEventListener('click', hideImage)

      // Prevent touch scroll in image viewer
      viewer.addEventListener(
        'touchmove',
        (e) => {
          if (viewer.classList.contains('active')) {
            e.preventDefault()
          }
        },
        { passive: false }
      )
    }

    // Replace any previous handler so re-initialization after view
    // transitions doesn't stack document-level listeners.
    const viewerWindow = window as { __imageViewerKeyHandler?: (e: KeyboardEvent) => void } & Window
    if (viewerWindow.__imageViewerKeyHandler) {
      document.removeEventListener('keydown', viewerWindow.__imageViewerKeyHandler)
    }
    const handleKeydown = (e: KeyboardEvent) => {
      if (e.key === 'Escape' && viewer.classList.contains('active')) {
        hideImage()
      }
    }
    document.addEventListener('keydown', handleKeydown)
    viewerWindow.__imageViewerKeyHandler = handleKeydown

    bindImageClickEvents()

    // Hide initially
    viewer.style.visibility = 'hidden'
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initImageViewer)
  } else {
    initImageViewer()
  }

  document.addEventListener('astro:page-load', initImageViewer)
</script>

<style>
  .image-viewer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.15s ease-in-out;
    background: color-mix(in srgb, var(--bg) 90%, transparent);
    cursor: zoom-out;
  }

  .image-viewer.active {
    opacity: 1;
  }

  .image-viewer img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    cursor: zoom-out;
  }

  body.image-viewer-open {
    overflow: hidden;
  }
</style>
