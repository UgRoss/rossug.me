---
// ABOUTME: Scattered polaroid-style travel photo gallery for the home page.
// ABOUTME: Images are optimized via astro:assets; per-card rotation comes from a CSS variable.

import type { ImageMetadata } from 'astro'

import { Image } from 'astro:assets'

import india from '@/assets/photos/me-india.jpg'
import malaga from '@/assets/photos/me-malaga.jpg'
import turkey from '@/assets/photos/me-turkey.jpg'

interface Photo {
  class?: string
  image: ImageMetadata
  location: string
  rotation: number
}

const photos: Photo[] = [
  { image: india, location: 'Agra, India', rotation: -10 },
  { class: 'hidden sm:block', image: malaga, location: 'Málaga, Spain', rotation: 3 },
  { image: turkey, location: 'Erciyes, Turkey', rotation: -10 }
]
---

<ul class="flex list-none items-center justify-center gap-6 p-0 pb-16 sm:gap-0">
  {
    photos.map((photo, index) => (
      <li class:list={['photo-card', photo.class]} style={`--rotation: ${photo.rotation}deg`}>
        <figure class="flex h-full flex-col">
          <div class="min-h-0 flex-1 overflow-hidden rounded-lg">
            <Image
              alt={`Ross in ${photo.location}`}
              class="h-full w-full object-cover"
              fetchpriority={index === 0 ? 'high' : 'auto'}
              loading="eager"
              src={photo.image}
              width={400}
            />
          </div>
          <figcaption class="truncate pt-1.5 text-center text-[0.7rem] font-medium">
            📍 {photo.location}
          </figcaption>
        </figure>
      </li>
    ))
  }
</ul>

<style>
  .photo-card {
    width: clamp(8.75rem, 40vw, 12.5rem);
    height: 11.25rem;
    padding: 0.4rem 0.4rem 0.5rem;
    border-radius: 0.75rem;
    background: var(--bg);
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.25),
      0 1px 4px rgba(0, 0, 0, 0.15);
    transform: rotate(var(--rotation));
    transition: transform 0.4s ease;
  }

  /* z-index works here without position because list items are flex items */
  .photo-card:hover {
    transform: rotate(0deg) scale(1.08);
    z-index: 10;
  }

  @media (min-width: 640px) {
    .photo-card {
      width: clamp(8.5rem, 15vw, 11.5rem);
      height: 13.75rem;
      margin: 0 -0.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-card {
      transition: none;
    }
  }
</style>
